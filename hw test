    "# Standardize the features using StandardScaler\n",
    "scaler = StandardScaler()\n",
    "X_train_scaled = pd.DataFrame(scaler.fit_transform(X_train), columns=X_train.columns)\n",
    "X_test_scaled = pd.DataFrame(scaler.transform(X_test), columns=X_test.columns)\n",
    "\n",
    "# Set up grid space of alphas\n",
    "alphas = range(100, 501, 10)\n",
    "ridge_cv_scores = []\n",
    "\n",
    "for alpha in alphas:\n",
    "    ridge = Ridge(alpha=alpha)\n",
    "    # compute negated MSE from 5-fold CV\n",
    "    neg_mse = cross_val_score(ridge, X_train_scaled, y_train, scoring='neg_mean_squared_error', cv=5, n_jobs=-1).mean()\n",
    "    ridge_cv_scores.append(np.sqrt(-neg_mse))\n",
    "\n",
    "# Find best alpha and best score\n",
    "best_idx = np.argmin(ridge_cv_scores)\n",
    "best_alpha = alphas[best_idx]\n",
    "best_ridge_rmse = ridge_cv_scores[best_idx]\n",
    "\n",
    "# Plot scores vs alphas\n",
    "plt.figure(figsize=(10, 5))\n",
    "plt.plot(alphas, ridge_cv_scores, marker='o', color='purple')\n",
    "plt.title(\"Ridge Regression: CV RMSE vs Alpha Hyperparameter\")\n",
    "plt.xlabel(\"Alpha\")\n",
    "plt.ylabel(\"CV RMSE ($)\")\n",
    "plt.grid(True)\n",
    "plt.show()\n",
    "\n",
    "print(f\"Best Ridge Alpha: {best_alpha}\")\n",
    "print(f\"Best Ridge CV RMSE: ${best_ridge_rmse:,.2f}\")"
   ]
